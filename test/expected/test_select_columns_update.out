/*
Tests that selected_columns filters both record and old_record on UPDATE:
- PKs are always included in record and old_record
- Columns not in selected_columns are excluded from both
*/
select 1 from pg_create_logical_replication_slot('realtime', 'wal2json', false);
 ?column? 
----------
        1
(1 row)

create table public.notes(
    id int primary key,
    body text,
    extra text
);
alter table public.notes replica identity full;
insert into realtime.subscription(subscription_id, entity, claims, selected_columns)
select
    seed_uuid(1),
    'public.notes',
    jsonb_build_object(
        'role', 'authenticated',
        'email', 'example@example.com',
        'sub', seed_uuid(1)::text
    ),
    array['body'];
insert into public.notes(id, body, extra) values (1, 'old body', 'extra data');
select clear_wal();
 clear_wal 
-----------
 
(1 row)

update public.notes set body = 'new body', extra = 'new extra' where id = 1;
select
    rec,
    is_rls_enabled,
    subscription_ids,
    errors
from
   walrus;
