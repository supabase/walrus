     "type": "DELETE",                             +|                |                                        | 
     "table": "notes",                             +|                |                                        | 
     "schema": "public",                           +|                |                                        | 
     "columns": [                                  +|                |                                        | 
         {                                         +|                |                                        | 
             "name": "id",                         +|                |                                        | 
             "type": "int4"                        +|                |                                        | 
         },                                        +|                |                                        | 
         {                                         +|                |                                        | 
             "name": "body",                       +|                |                                        | 
